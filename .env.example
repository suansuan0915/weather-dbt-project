# Copy this file to .env for local development.
# Do not commit real secrets to git.

# v1 current stack
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# v2 migration stack

# Google Cloud
GCP_PROJECT_ID=
GCS_BUCKET=
GCS_RAW_PREFIX=weather/raw/open_meteo
GOOGLE_APPLICATION_CREDENTIALS=

# Databricks connection
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=

# Databricks logical layout
DATABRICKS_CATALOG=weather_dev
DATABRICKS_BRONZE_SCHEMA=bronze
DATABRICKS_SILVER_SCHEMA=silver
DATABRICKS_GOLD_SCHEMA=gold
